# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GA_MEASUREMENT_ID: Google Analytics 4 Measurement ID.
# Get from: https://analytics.google.com/analytics/web/
# Format: G-XXXXXXXXXX
# Never commit a real measurement ID's associated secrets; the ID itself is
# not sensitive (it's public in every page's source), but keep dev/prod
# properties separate if you want clean data.
VITE_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# EmailJS: powers the Admissions and Contact form submissions (client-side,
# no backend needed). Sign up free at https://www.emailjs.com/
# - VITE_EMAILJS_SERVICE_ID: your connected email service (e.g. Gmail) ID
# - VITE_EMAILJS_PUBLIC_KEY: your account's public key (safe to expose client-side;
#   this is how EmailJS is designed to work for static sites -- it identifies your
#   account, it isn't a secret credential)
# - VITE_EMAILJS_ADMISSIONS_TEMPLATE_ID / VITE_EMAILJS_CONTACT_TEMPLATE_ID: the two
#   email templates you create in the EmailJS dashboard, one per form. See
#   src/lib/email.ts for the exact field names each template should expect
#   ({{student_name}}, {{target_grade}}, {{parent_name}}, {{phone}}, {{email}},
#   {{additional_info}} for admissions; {{name}}, {{email}}, {{subject}},
#   {{message}} for contact).
# Until all four are set, isEmailConfigured() returns false and both forms show
# the error state instead of silently pretending to succeed.
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="your_public_key"
VITE_EMAILJS_ADMISSIONS_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_CONTACT_TEMPLATE_ID="template_xxxxxxx"
